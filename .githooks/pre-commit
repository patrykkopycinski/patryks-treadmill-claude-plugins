#!/usr/bin/env bash
# Pre-commit guard for this repo. Enable once with:
#   git config core.hooksPath .githooks
# Runs the same checks CI enforces, so branding leaks / broken plugins
# are caught before they leave the machine.
set -uo pipefail

REPO="$(git rev-parse --show-toplevel)"
cd "$REPO"

fail=0
bash scripts/check-branding.sh   || fail=1
bash scripts/validate-plugins.sh --strict || fail=1
bash scripts/test-context-root.sh || fail=1

if [ $fail -ne 0 ]; then
  echo ""
  echo "✗ pre-commit checks failed — fix the issues above or commit with --no-verify to bypass."
  exit 1
fi
