{
  "name": "ai-chat-browser",
  "version": "0.1.0",
  "description": "Unified MCP server that indexes and searches past Claude Code and Cursor AI conversations",
  "license": "Elastic-2.0",
  "author": "Patryk Kopycinski",
  "type": "module",
  "main": "dist/index.js",
