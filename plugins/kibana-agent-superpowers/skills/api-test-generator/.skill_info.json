{
  "name": "api-test-generator",
  "version": "1.0.0",
  "description": "Auto-generate comprehensive Scout API tests from Kibana route definitions",
  "author": "Patryk Kopycinski",
  "created": "2026-03-20",
  "activation_phrases": [
    "generate API tests",
    "create tests for endpoint",
    "test this API",
    "generate Scout tests"
  ],
  "capabilities": [
    "Parse versioned Kibana route definitions",
    "Extract route metadata (path, method, access, authz)",
    "Extract request/response schemas",
    "Generate valid/invalid test data from schemas",
    "Generate RBAC tests (viewer, editor, admin)",
    "Generate authentication tests (401/403)",
    "Generate validation tests (400)",
    "Generate edge case tests",
    "Produce Scout-compatible test files"
  ],
  "requirements": [
    "Target route must use Kibana versioned routing",
    "Route must have @kbn/config-schema validation",
    "RBAC configuration should be present"
  ],
  "outputs": [
    "Complete Scout test file",
    "Constants file (if new plugin)",
    "Scout config (if new plugin)",
    "Test run command"
  ],
  "files": {
    "SKILL.md": "Main skill instructions",
    "helpers.md": "Reusable patterns and mappings",
    "example_output.ts": "Complete example of generated tests",
    "README.md": "Overview and documentation",
    "QUICK_REFERENCE.md": "Quick lookup for common scenarios"
  },
  "test_coverage": {
    "valid_requests": "200 OK with valid data",
    "rbac": "Role-based access control for all roles",
    "authentication": "401 Unauthorized without auth",
    "validation": "400 Bad Request with invalid data",
    "edge_cases": "Boundaries, special chars, unicode"
  },
  "kibana_integration": {
    "test_framework": "Scout (@kbn/scout/api)",
    "route_system": "Versioned routes",
    "schema_system": "@kbn/config-schema",
    "auth_system": "requestAuth service",
    "conventions": ["snake_case filenames", "COMMON_HEADERS", "apiTest blocks"]
  }
}
